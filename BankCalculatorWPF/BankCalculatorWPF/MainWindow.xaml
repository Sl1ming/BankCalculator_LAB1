<Window x:Class="BankCalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankCalculatorWPF"
        mc:Ignorable="d"
        Title="Професійний Банківський Калькулятор" Height="650" Width="450"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" FontFamily="Segoe UI">

	<Window.Resources>
		<Style x:Key="LabelStyle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#34495E"/>
			<Setter Property="Margin" Value="0,10,0,3"/>
		</Style>

		<Style x:Key="InputStyle" TargetType="TextBox">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#BDC3C7"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="SnapsToDevicePixels" Value="True"/>
			<Style.Resources>
				<Style TargetType="Border">
					<Setter Property="CornerRadius" Value="5"/>
				</Style>
			</Style.Resources>
		</Style>

		<Style x:Key="ComboBoxStyle" TargetType="ComboBox">
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
		</Style>

		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#2980B9"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="15,10"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Style.Resources>
				<Style TargetType="Border">
					<Setter Property="CornerRadius" Value="5"/>
				</Style>
			</Style.Resources>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#3498DB"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
			<Setter Property="Background" Value="#27AE60"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#2ECC71"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<Grid Margin="15">
		<Border Background="White" CornerRadius="15" Padding="20">
			<Border.Effect>
				<DropShadowEffect BlurRadius="15" Color="#D0D0D0" ShadowDepth="3" Opacity="0.5"/>
			</Border.Effect>

			<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-10,0" Padding="0,0,10,0">
				<StackPanel>
					<TextBlock Text="BankIQ Calculator" FontSize="26" FontWeight="ExtraBold"
                               Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
					<Separator Background="#ECF0F1" Margin="0,0,0,10"/>

					<TextBlock Text="Сума (грн):" Style="{StaticResource LabelStyle}"/>
					<TextBox x:Name="txtAmount" Style="{StaticResource InputStyle}" Text="10000"/>

					<TextBlock Text="Річна ставка (%):" Style="{StaticResource LabelStyle}"/>
					<TextBox x:Name="txtRate" Style="{StaticResource InputStyle}" Text="15"/>

					<TextBlock Text="Термін (місяців):" Style="{StaticResource LabelStyle}"/>
					<TextBox x:Name="txtTerm" Style="{StaticResource InputStyle}" Text="12"/>

					<TextBlock Text="Тип операції:" Style="{StaticResource LabelStyle}"/>
					<ComboBox x:Name="cmbType" Style="{StaticResource ComboBoxStyle}" SelectedIndex="1">
						<ComboBoxItem Content="Депозит (Прості відсотки)"/>
						<ComboBoxItem Content="Депозит (Складні %, щомісячна капіталізація)"/>
						<ComboBoxItem Content="Кредит (Ануїтетні платежі)"/>
					</ComboBox>

					<Button x:Name="btnCalculate" Content="Розрахувати"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,15,0,10"
                            Click="btnCalculate_Click"/>

					<Border x:Name="resultBorder" Background="#F8F9FA" BorderBrush="#EAECEF"
                            BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,15" Visibility="Collapsed">
						<StackPanel>
							<TextBlock Text="Результат розрахунку:" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,5"/>
							<TextBlock x:Name="lblResultMain" Text="0.00 грн" FontSize="22" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,5"/>
							<TextBlock x:Name="lblResultDetails" Text="Деталі..." FontSize="14" Foreground="#34495E" TextWrapping="Wrap"/>
						</StackPanel>
					</Border>

					<Button x:Name="btnSave" Content="Зберегти звіт у PDF/TXT"
                            Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"
                            Margin="0,0,0,10" Click="btnSave_Click" IsEnabled="False"/>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</Window>