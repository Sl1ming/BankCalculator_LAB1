<Window x:Class="BankCalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Банківський Калькулятор (WPF)" Height="450" Width="400">

    <StackPanel Margin="20">

        <TextBlock Text="Сума вкладу:" Margin="0,10,0,5"/>
        <TextBox x:Name="txtAmount" Height="25" Padding="2"/>

        <TextBlock Text="Річна ставка (%):" Margin="0,10,0,5"/>
        <TextBox x:Name="txtRate" Height="25" Padding="2"/>

        <TextBlock Text="Термін (місяців):" Margin="0,10,0,5"/>
        <TextBox x:Name="txtTerm" Height="25" Padding="2"/>

        <Button x:Name="btnCalculate" Content="Розрахувати" 
                Click="btnCalculate_Click" Margin="0,20,0,5" Height="30"/>

        <Button x:Name="btnSave" Content="Зберегти звіт" 
                Click="btnSave_Click" Height="30"/>

        <TextBlock x:Name="lblResult" Text="Тут буде результат" 
                   FontSize="16" FontWeight="Bold" Margin="0,20,0,0" 
                   HorizontalAlignment="Center"/>

    </StackPanel>
</Window>